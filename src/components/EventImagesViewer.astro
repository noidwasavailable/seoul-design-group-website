---
import type { ImageMetadata } from "astro";
import EventImage from "@/components/EventImage.astro";
import IconX from "@/assets/icons/IconX.svg";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import generatePhotoGrid from "@/utils/generatePhotoGrid";

type Props = {
	eventId: string;
	eventDate: Date;
};

const { eventId, eventDate } = Astro.props;

// Eagerly import all event images at build time
const allImages = import.meta.glob<{ default: ImageMetadata }>(
	"/src/data/events/*/images/*.{jpeg,jpg,png,webp,avif}",
	{ eager: true },
);

// Filter to only this event's images and sort by filename
const images = Object.entries(allImages)
	.filter(([path]) => path.includes(`/events/${eventId}/images/`))
	.sort(([a], [b]) => a.localeCompare(b))
	.map(([path, mod]) => ({
		src: mod.default,
		filename: path.split("/").pop() ?? "",
		isLandscape: mod.default.width > mod.default.height,
		isPortrait: mod.default.height > mod.default.width * 1.3,
	}));

const dateStr = eventDate.toLocaleDateString("ko-KR");

const desktopGrid = generatePhotoGrid(images, 4);
const mobileGrid = generatePhotoGrid(images, 2);
---

{images.length > 0 && (
<section aria-label="Event photos">
	<h2 class="text-2xl font-semibold mb-5 text-foreground">Photos</h2>
	<div
		class="grid auto-rows-[220px] gap-2 sm:auto-rows-[260px] sm:gap-2 grid-cols-2 sm:grid-cols-4"
		style="grid-auto-flow: dense;"
		id="gallery-grid"
	>
	{images.map((image, i) => (
		<button
			type="button"
			class:list={[
				"gallery-cell",
				"relative overflow-hidden cursor-pointer border-none p-0 bg-transparent",
				"transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]",
				"hover:scale-[1.03] hover:shadow-[0_12px_28px_-4px_rgba(0,0,0,0.15),0_4px_10px_-2px_rgba(0,0,0,0.08)]",
				"focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2",
				// Mobile spans (2nd column layout)
				{ "col-span-2": mobileGrid.wideSet.has(i) },
				{ "row-span-2": mobileGrid.tallSet.has(i) },
				// Desktop spans (4th column layout) - override mobile spans
				{ "sm:col-span-2": desktopGrid.wideSet.has(i) },
				{ "sm:row-span-2": desktopGrid.tallSet.has(i) },
				// Reset if big in mobile but small in desktop
				{ "sm:col-span-1": !desktopGrid.wideSet.has(i) && mobileGrid.wideSet.has(i) },
				{ "sm:row-span-1": !desktopGrid.tallSet.has(i) && mobileGrid.tallSet.has(i) },
			]}
			data-index={i}
			data-landscape={image.isLandscape ? "true" : "false"}
			data-portrait={image.isPortrait ? "true" : "false"}
			style={`animation: fadeSlideIn 0.5s ease both; animation-delay: ${i * 60}ms`}
			aria-label={`View photo ${i + 1} of ${images.length}`}
		>
			<EventImage src={image.src} eventDate={dateStr} index={i} />
		</button>
))}
	</div>

	<!-- Lightbox -->
	<div
		id="lightbox"
		class="fixed inset-0 z-100 flex items-center justify-center opacity-0 invisible transition-all duration-300 data-[open=true]:opacity-100 data-[open=true]:visible"
		role="dialog"
		aria-modal="true"
		aria-label="Image viewer"
	>
		<div
			id="lightbox-backdrop"
			class="absolute inset-0 bg-black/85 backdrop-blur-xl"
		></div>
		<div class="relative z-1 flex flex-col w-full h-full max-w-screen max-h-screen">
			<div class="flex justify-between items-center px-5 py-4 text-white/85">
				<span
					id="lightbox-counter"
					class="text-sm tabular-nums tracking-wider opacity-70"
				></span>
				<button
					type="button"
					id="lightbox-close"
					class="flex items-center justify-center size-10 rounded-full border-none bg-white/10 text-white cursor-pointer transition-all duration-200 hover:bg-white/20 hover:scale-110"
					aria-label="Close image viewer"
				>
					<IconX class="size-5" />
				</button>
			</div>
			<div class="flex items-center justify-center flex-1 min-h-0 gap-2 px-2 pb-6">
				<button
					type="button"
					id="lightbox-prev"
					class="flex items-center justify-center shrink-0 size-12 sm:size-10 rounded-full border-none bg-white/8 text-white/80 cursor-pointer transition-all duration-200 hover:bg-white/18 hover:text-white hover:scale-110"
					aria-label="Previous image"
				>
					<IconChevronLeft class="size-7 sm:size-5" />
				</button>
				<div
					id="lightbox-image-wrapper"
					class="flex-1 flex items-center justify-center min-w-0 min-h-0 max-h-full [&_img]:max-w-full [&_img]:max-h-[calc(100vh-8rem)] [&_img]:object-contain [&_img]:rounded-lg [&_img]:transition-all [&_img]:duration-300 [&_img]:ease-[cubic-bezier(0.22,1,0.36,1)] [&_img]:select-none"
				>
					<!-- Image injected via JS -->
				</div>
				<button
					type="button"
					id="lightbox-next"
					class="flex items-center justify-center shrink-0 size-12 sm:size-10 rounded-full border-none bg-white/8 text-white/80 cursor-pointer transition-all duration-200 hover:bg-white/18 hover:text-white hover:scale-110"
					aria-label="Next image"
				>
					<IconChevronRight class="size-7 sm:size-5" />
				</button>
			</div>
		</div>
	</div>
</section>
)}

<style>
	/* Gallery cell image styling */
	.gallery-cell :global(img) {
		@apply w-full h-full object-cover block transition-transform duration-400 ease-[cubic-bezier(0.22,1,0.36,1)];
	}

	.gallery-cell:hover :global(img) {
		@apply scale-[1.06];
	}

	/* Entrance animation — can't be a utility */
	@keyframes fadeSlideIn {
		from {
			opacity: 0;
			transform: translateY(16px) scale(0.97);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}
</style>

<script>
	import generatePhotoGrid from "@/utils/generatePhotoGrid";

	document.addEventListener("astro:page-load", () => {
	const grid = document.getElementById("gallery-grid");
	const lightbox = document.getElementById("lightbox");
	const backdrop = document.getElementById("lightbox-backdrop");
	const closeBtn = document.getElementById("lightbox-close");
	const prevBtn = document.getElementById("lightbox-prev");
	const nextBtn = document.getElementById("lightbox-next");
	const counter = document.getElementById("lightbox-counter");
	const imageWrapper = document.getElementById("lightbox-image-wrapper");

	if (!grid || !lightbox || !imageWrapper) return;

	// Responsive grid logic
	const cells = Array.from(grid.querySelectorAll(".gallery-cell")) as HTMLElement[];
	const imageData = cells.map((cell) => ({
		src: { src: "", width: 0, height: 0, format: "jpg" } as any, // Placeholder for type compatibility
		filename: "",
		isLandscape: cell.dataset.landscape === "true",
		isPortrait: cell.dataset.portrait === "true",
	}));

	let lastColCount = 0;

	function updateGrid() {
		const width = window.innerWidth;
		const colCount = width < 640 ? 2 : 4;

		if (colCount === lastColCount) return;
		lastColCount = colCount;

		const { wideSet, tallSet } = generatePhotoGrid(imageData, colCount);

		// Remove all previous span classes to avoid conflicts with static classes
		cells.forEach((cell, i) => {
			cell.classList.remove("col-span-1", "col-span-2", "row-span-1", "row-span-2", "sm:col-span-1", "sm:col-span-2", "sm:row-span-1", "sm:row-span-2");
			
			if (wideSet.has(i)) {
				cell.classList.add("col-span-2");
			} else {
				cell.classList.add("col-span-1");
			}

			if (tallSet.has(i)) {
				cell.classList.add("row-span-2");
			} else {
				cell.classList.add("row-span-1");
			}
		});

		grid!.style.gridTemplateColumns = `repeat(${colCount}, 1fr)`;
	}

	window.addEventListener("resize", updateGrid);
	// Initial call skipped if already correct to avoid flicker, but here we can keep it 
	// because it will return early if colCount is the same (and we initialized lastColCount correctly)
	// Actually, let's initialize lastColCount based on current width.
	const initialWidth = window.innerWidth;
	lastColCount = initialWidth < 640 ? 2 : 4;
	const imageSrcs = cells.map((cell) => {
		const img = cell.querySelector("img");
		return img?.currentSrc || img?.src || "";
	});

	let currentIndex = 0;
	let touchStartX = 0;
	let touchEndX = 0;

	function showImage(index: number) {
		currentIndex = ((index % imageSrcs.length) + imageSrcs.length) % imageSrcs.length;
		const src = imageSrcs[currentIndex];

		imageWrapper!.innerHTML = `<img src="${src}" alt="Event photo ${currentIndex + 1}" draggable="false" />`;
		counter!.textContent = `${currentIndex + 1} / ${imageSrcs.length}`;
	}

	function openLightbox(index: number) {
		showImage(index);
		lightbox!.dataset.open = "true";
		document.body.style.overflow = "hidden";
	}

	function closeLightbox() {
		lightbox!.dataset.open = "";
		document.body.style.overflow = "";
	}

	// Grid cell click handlers
	cells.forEach((cell, i) => {
		cell.addEventListener("click", () => openLightbox(i));
	});

	// Navigation
	prevBtn?.addEventListener("click", (e) => {
		e.stopPropagation();
		showImage(currentIndex - 1);
	});

	nextBtn?.addEventListener("click", (e) => {
		e.stopPropagation();
		showImage(currentIndex + 1);
	});

	// Close
	closeBtn?.addEventListener("click", closeLightbox);
	backdrop?.addEventListener("click", closeLightbox);

	// Keyboard
	document.addEventListener("keydown", (e) => {
		if (lightbox!.dataset.open !== "true") return;

		switch (e.key) {
			case "Escape":
				closeLightbox();
				break;
			case "ArrowLeft":
				showImage(currentIndex - 1);
				break;
			case "ArrowRight":
				showImage(currentIndex + 1);
				break;
		}
	});

	// Touch swipe
	lightbox?.addEventListener("touchstart", (e) => {
		touchStartX = (e as TouchEvent).changedTouches[0].screenX;
	}, { passive: true });

	lightbox?.addEventListener("touchend", (e) => {
		touchEndX = (e as TouchEvent).changedTouches[0].screenX;
		const diff = touchStartX - touchEndX;
		if (Math.abs(diff) > 50) {
			if (diff > 0) showImage(currentIndex + 1);
			else showImage(currentIndex - 1);
		}
	}, { passive: true });
});
</script>
