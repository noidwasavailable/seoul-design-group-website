---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

type Props = {
	src: ImageMetadata;
	eventDate: string;
	class?: string;
	index?: number;
};

const { src, eventDate, class: className, index = 0 } = Astro.props;
---

<Picture
	src={src}
	formats={['avif', 'webp', 'jpeg']}
	layout="constrained"
	alt={`A photo from the event at ${eventDate}`}
	class:list={["event-image", className]}
	loading={index < 4 ? "eager" : "lazy"}
/>
