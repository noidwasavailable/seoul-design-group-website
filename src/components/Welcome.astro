---
import type { CollectionEntry } from "astro:content";
import Card from "./Card.astro";
import LinkButton from "./LinkButton.astro";
import LumaEvent from "./LumaEvent.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import IconExternalLink from "@/assets/icons/IconExternalLink.svg";
import type { LumaEvent as LumaEventType } from "@/utils/getLumaEvents";
import { SITE } from "@/config";

type Props = {
	recentEvents: CollectionEntry<"events">[];
	upcomingEvents?: LumaEventType[];
};

const { recentEvents, upcomingEvents } = Astro.props;
---

<!-- Hero -->
<section class="app-layout pt-16 pb-20 sm:pt-24 sm:pb-28 text-center">
	<p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent mb-4 animate-fade-in">
		Seoul, South Korea
	</p>
	<h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.15] text-foreground mb-6 animate-fade-in-up">
		Seoul Design Group
	</h1>
	<p class="max-w-xl mx-auto text-lg sm:text-xl leading-relaxed text-foreground/70 mb-10 animate-fade-in-up-delay">
		A community of designers, artists, and creatives in Seoul —
		sharing ideas, exchanging inspiration, and building together.
	</p>
	<div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up-delay-2">
		<a
			href={SITE.luma.LUMA_CALENDAR_URL}
			target="_blank"
			rel="noopener noreferrer"
			class="inline-flex items-center gap-2 px-7 py-3.5 bg-accent text-white font-medium rounded-lg transition-all hover:opacity-90 hover:shadow-md active:scale-[0.98]"
		>
			Join us on Luma
			<IconExternalLink class="size-4 opacity-80" />
		</a>
		<a
			href="/about"
			class="inline-flex items-center gap-1.5 px-7 py-3.5 border border-border text-foreground font-medium rounded-lg transition-all hover:border-accent hover:text-accent"
		>
			Learn more
			<IconArrowRight class="size-4" />
		</a>
	</div>
</section>

<!-- Upcoming Events -->
<section class="app-layout pb-16">
	<div class="border-t border-border pt-12">
		<div class="flex items-baseline justify-between mb-4">
			<h2 class="text-2xl sm:text-3xl font-semibold text-foreground">
				Upcoming Events
			</h2>
			<a
				href={SITE.luma.LUMA_CALENDAR_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="text-sm font-medium text-accent hover:underline underline-offset-4 inline-flex items-center gap-1"
			>
				View calendar on Luma
				<IconExternalLink class="size-3.5 opacity-70" />
			</a>
		</div>

		{upcomingEvents &&upcomingEvents.length > 0 ? (
			<ul class="space-y-3">
				{upcomingEvents.slice(0, 3).map((event) => (<LumaEvent event={event} />))}
			</ul>
		) : (
			<div class="rounded-xl border border-dashed border-border p-4 sm:p-5">
				<p class="text-sm text-foreground/70 mb-3">
					No upcoming events listed right now.
				</p>
			</div>
		)}
	</div>
</section>

<!-- Recent Events -->
{recentEvents.length > 0 && (
	<section class="app-layout pb-16">
		<div class="border-t border-border pt-12">
			<div class="flex items-baseline justify-between mb-2">
				<h2 class="text-2xl sm:text-3xl font-semibold text-foreground">
					Recent Events
				</h2>
				<LinkButton
					href="/events"
					class="text-sm font-medium text-accent hover:underline underline-offset-4"
				>
					View all <IconArrowRight class="size-3.5 inline-block" />
				</LinkButton>
			</div>
			<ul>
				{recentEvents.map(event => <Card {...event} />)}
			</ul>
		</div>
	</section>
)}

<!-- Sponsors -->
<section class="app-layout pb-16">
	<div class="border-t border-border pt-12">
		<div class="text-center max-w-lg mx-auto">
			<h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-4">
				Our Sponsors
			</h2>
			<p class="text-foreground/70 leading-relaxed mb-8">
				We're a volunteer-run community and our events are free for everyone.
				Sponsors help us secure great venues, provide refreshments, and keep this community growing.
			</p>
			<div class="py-10 px-6 border border-dashed border-border rounded-xl mb-8">
				<p class="text-foreground/40 text-sm italic">
					Your brand here — be part of Seoul's creative community
				</p>
			</div>
			<a
				href="mailto:hello@seouldesigngroup.com?subject=Sponsorship%20Inquiry"
				class="inline-flex items-center gap-2 px-7 py-3.5 bg-foreground text-background font-medium rounded-lg transition-all hover:opacity-90 hover:shadow-md active:scale-[0.98]"
			>
				Become a Sponsor
			</a>
		</div>
	</div>
</section>

<!-- Community CTA -->
<section class="app-layout pb-20">
	<div class="border-t border-border pt-12">
		<div class="text-center max-w-lg mx-auto">
			<h2 class="text-2xl sm:text-3xl font-semibold text-foreground mb-4">
				Are you a creative in Seoul?
			</h2>
			<p class="text-foreground/70 leading-relaxed mb-8">
				Whether you're a designer, developer, artist, or simply curious —
				you're welcome here. Follow us on Luma and join the next event.
			</p>
			<a
				href={SITE.luma.LUMA_CALENDAR_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 px-7 py-3.5 bg-accent text-white font-medium rounded-lg transition-all hover:opacity-90 hover:shadow-md active:scale-[0.98]"
			>
				See upcoming events
				<IconExternalLink class="size-4 opacity-80" />
			</a>
		</div>
	</div>
</section>

<style>
	@keyframes fade-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	@keyframes fade-in-up {
		from { opacity: 0; transform: translateY(12px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.animate-fade-in {
		animation: fade-in 0.6s ease-out both;
	}
	.animate-fade-in-up {
		animation: fade-in-up 0.6s ease-out 0.15s both;
	}
	.animate-fade-in-up-delay {
		animation: fade-in-up 0.6s ease-out 0.3s both;
	}
	.animate-fade-in-up-delay-2 {
		animation: fade-in-up 0.6s ease-out 0.45s both;
	}
</style>
